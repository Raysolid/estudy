<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.estudy.mappers.UserMapper">

    <!--实体映射-->
    <resultMap id="base_result_map" type="com.estudy.entity.po.User">
        <!--用户id-->
        <result column="user_id" property="userId"/>
        <!--邮箱-->
        <result column="email" property="email"/>
        <!--昵称-->
        <result column="nickname" property="nickname"/>
        <!--密码-->
        <result column="password" property="password"/>
        <!--积分-->
        <result column="points" property="points"/>
        <!--等级-->
        <result column="preference" property="preference"/>
        <!--注册时间-->
        <result column="create_time" property="createTime"/>
    </resultMap>


    <!-- 通用查询结果列-->
    <sql id="base_column_list">
        u.user_id
        ,u.email,u.nickname,u.password,u.points,
		 u.preference,u.create_time
    </sql>

    <sql id="base_condition_filed">
        <foreach collection="query.conditions.entrySet()" index="key" item="value" separator=" ">
            <if test="value != null">
                and ${key} = #{value}
            </if>
        </foreach>
    </sql>
    <!-- 通用条件列-->
    <sql id="base_condition">
        <where>
            <include refid="base_condition_filed"/>
        </where>
    </sql>

    <!-- 通用查询条件列-->
    <sql id="query_condition">
        <where>
            <include refid="base_condition_filed"/>
            <foreach collection="query.fuzzyConditions.entrySet()" index="key" item="value" separator=" ">
                <if test="value != null">
                    and ${key} like concat('%', #{value}, '%')
                </if>
            </foreach>
        </where>
    </sql>

    <!-- 查询集合-->
    <select id="selectList" resultMap="base_result_map">
        SELECT
        <include refid="base_column_list"/>
        FROM user u
        <include refid="query_condition"/>
        <if test="query.orderBy!=null">
            order by ${query.orderBy}
        </if>
        <if test="query.simplePage!=null">
            limit #{query.simplePage.start},#{query.simplePage.end}
        </if>
    </select>

    <!-- 查询数量-->
    <select id="selectCount" resultType="java.lang.Integer">
        SELECT count(1) FROM user u
        <include refid="query_condition"/>
    </select>

    <!-- 插入 （匹配有值的字段）-->
    <insert id="insert" parameterType="com.estudy.entity.po.User">
        INSERT INTO user
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="bean.userId != null">
                user_id,
            </if>
            <if test="bean.email != null">
                email,
            </if>
            <if test="bean.nickname != null">
                nickname,
            </if>
            <if test="bean.password != null">
                password,
            </if>
            <if test="bean.points != null">
                points,
            </if>
            <if test="bean.preference != null">
                preference,
            </if>
            <if test="bean.createTime != null">
                create_time,
            </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="bean.userId!=null">
                #{bean.userId},
            </if>
            <if test="bean.email!=null">
                #{bean.email},
            </if>
            <if test="bean.nickname!=null">
                #{bean.nickname},
            </if>
            <if test="bean.password!=null">
                #{bean.password},
            </if>
            <if test="bean.points!=null">
                #{bean.points},
            </if>
            <if test="bean.preference!=null">
                #{bean.preference},
            </if>
            <if test="bean.createTime!=null">
                #{bean.createTime},
            </if>
        </trim>
    </insert>

    <!-- 插入或者更新 （匹配有值的字段）-->
    <insert id="insertOrUpdate" parameterType="com.estudy.entity.po.User">
        INSERT INTO user
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="bean.userId != null">
                user_id,
            </if>
            <if test="bean.email != null">
                email,
            </if>
            <if test="bean.nickname != null">
                nickname,
            </if>
            <if test="bean.password != null">
                password,
            </if>
            <if test="bean.points != null">
                points,
            </if>
            <if test="bean.preference != null">
                preference,
            </if>
            <if test="bean.createTime != null">
                create_time,
            </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="bean.userId!=null">
                #{bean.userId},
            </if>
            <if test="bean.email!=null">
                #{bean.email},
            </if>
            <if test="bean.nickname!=null">
                #{bean.nickname},
            </if>
            <if test="bean.password!=null">
                #{bean.password},
            </if>
            <if test="bean.points!=null">
                #{bean.points},
            </if>
            <if test="bean.preference!=null">
                #{bean.preference},
            </if>
            <if test="bean.createTime!=null">
                #{bean.createTime},
            </if>
        </trim>
        on DUPLICATE key update
        <trim prefix="" suffix="" suffixOverrides=",">
            <if test="bean.userId!=null">
                user_id = VALUES(user_id),
            </if>
            <if test="bean.email!=null">
                email = VALUES(email),
            </if>
            <if test="bean.nickname!=null">
                nickname = VALUES(nickname),
            </if>
            <if test="bean.password!=null">
                password = VALUES(password),
            </if>
            <if test="bean.points!=null">
                points = VALUES(points),
            </if>
            <if test="bean.preference!=null">
                preference = VALUES(preference),
            </if>
            <if test="bean.createTime!=null">
                create_time = VALUES(create_time),
            </if>
        </trim>
    </insert>

    <!-- 添加 （批量插入）-->
    <insert id="insertBatch" parameterType="com.estudy.entity.po.User">
        INSERT INTO user(
        user_id,
        email,
        nickname,
        password,
        points,
        preference,
        create_time
        )values
        <foreach collection="list" item="item" separator=",">
            (
            #{item.userId},
            #{item.email},
            #{item.nickname},
            #{item.password},
            #{item.points},
            #{item.preference},
            #{item.createTime}
            )
        </foreach>
    </insert>

    <!-- 批量新增修改 （批量插入）-->
    <insert id="insertOrUpdateBatch" parameterType="com.estudy.entity.po.User">
        INSERT INTO user(
        user_id,
        email,
        nickname,
        password,
        points,
        preference,
        create_time
        )values
        <foreach collection="list" item="item" separator=",">
            (
            #{item.userId},
            #{item.email},
            #{item.nickname},
            #{item.password},
            #{item.points},
            #{item.preference},
            #{item.createTime}
            )
        </foreach>
        on DUPLICATE key update
        user_id = VALUES(user_id),
        email = VALUES(email),
        nickname = VALUES(nickname),
        password = VALUES(password),
        points = VALUES(points),
        preference = VALUES(preference),
        create_time = VALUES(create_time)
    </insert>

    <!--多条件修改-->
    <update id="updateByParam" parameterType="com.estudy.entity.query.QueryParams">
        UPDATE user u
        <set>
            <if test="bean.userId != null">
                user_id = #{bean.userId},
            </if>
            <if test="bean.email != null">
                email = #{bean.email},
            </if>
            <if test="bean.nickname != null">
                nickname = #{bean.nickname},
            </if>
            <if test="bean.password != null">
                password = #{bean.password},
            </if>
            <if test="bean.points != null">
                points = #{bean.points},
            </if>
            <if test="bean.preference != null">
                preference = #{bean.preference},
            </if>
            <if test="bean.createTime != null">
                create_time = #{bean.createTime},
            </if>
        </set>
        <include refid="query_condition"/>
    </update>

    <!--多条件删除-->
    <delete id="deleteByParam">
        delete u from user u
        <include refid="query_condition"/>
    </delete>

    <!-- 根据UserId修改-->
    <update id="updateById" parameterType="com.estudy.entity.po.User">
        UPDATE user
        <set>
            <if test="bean.email != null">
                email = #{bean.email},
            </if>
            <if test="bean.nickname != null">
                nickname = #{bean.nickname},
            </if>
            <if test="bean.password != null">
                password = #{bean.password},
            </if>
            <if test="bean.points != null">
                points = #{bean.points},
            </if>
            <if test="bean.preference != null">
                preference = #{bean.preference},
            </if>
            <if test="bean.createTime != null">
                create_time = #{bean.createTime},
            </if>
        </set>
        where user_id=#{bean.userId}
    </update>

    <!-- 根据UserId删除-->
    <delete id="deleteById">
        delete
        from user
        where user_id = #{id}
    </delete>

    <!-- 根据PrimaryKey获取对象-->
    <select id="selectById" resultMap="base_result_map">
        select
        <include refid="base_column_list"/>
        from user u where user_id=#{id}
    </select>

    <!-- 根据PrimaryKey获取对象-->
    <select id="selectByEmail" resultMap="base_result_map">
        select
        <include refid="base_column_list"/>
        from user u where email=#{email}
    </select>

    <!-- 更新用户积分 -->
    <update id="updateUserPoints">
        update user set points = points + #{points}
        where user_id = #{userId} and (#{points} >= 0 or points >= -#{points})
    </update>

    <!-- 查询积分情况 -->
    <select id="selectPointsCount" resultType="java.util.Map">
        select
            sum(points) as totalPoints,
            avg(points) as avgPoints,
            max(points) as maxPoints
        from user
    </select>

</mapper>